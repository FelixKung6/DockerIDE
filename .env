# ==============================================================================
# Ubuntu 开发环境 - 环境变量配置
# ==============================================================================
# ⚠️ 此文件包含敏感信息，请勿上传到版本控制系统！
# ⚠️ 建议将此文件添加到 .gitignore

# ---------- 容器基础配置 ----------
CONTAINER_NAME=dev-ide-ubuntu
CONTAINER_HOSTNAME=Felix-IDE

# ---------- 用户安全配置 ----------
USER_NAME=FelixKung
USER_UID=6000
USER_GID=6000
# ⚠️ 重要：加入 sudo 组，不加入 root 组
USER_GROUPS=sudo,video,audio,plugdev
# ⚠️ 请修改为强密码！
USER_PASSWORD=${USER_NAME}
VNC_PASSWORD=${USER_NAME}
WEB_PASSWORD=${USER_NAME}

# ---------- 时区配置 ----------
TZ=Asia/Shanghai

# ---------- 网络端口配置 ----------
VNC_PORT_HOST=5901
VNC_PORT_CONTAINER=5901
WEB_PORT_HOST=6080
WEB_PORT_CONTAINER=6080
SSH_PORT_HOST=2222
SSH_PORT_CONTAINER=22

# ---------- 存储路径配置 ----------
HOST_BASE_PATH=/f/WorkStudio/MMT
HOST_WORKSPACE_PATH=${HOST_BASE_PATH}/data
CONTAINER_WORKSPACE_PATH=/home/${USER_NAME}/workspace
HOST_CONFIG_PATH=${HOST_BASE_PATH}/data/config
CONTAINER_CONFIG_PATH=/home/${USER_NAME}/.config
HOST_BACKUP_PATH=${HOST_BASE_PATH}/data/backups
CONTAINER_BACKUP_PATH=/home/${USER_NAME}/backups

# ---------- 资源限制配置 ----------
CPU_LIMIT=6
MEMORY_LIMIT=12g
SHM_SIZE=6g

# ---------- 镜像配置 ----------
BASE_IMAGE=ubuntu:24.04
CUSTOM_IMAGE_NAME=dev-ide-ubuntu
IMAGE_VERSION=1.0.0